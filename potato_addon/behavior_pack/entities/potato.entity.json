{
  "format_version": "1.20.10",
  "minecraft:entity": {
    "description": {
      "identifier": "potato:potato",
      
      "is_spawnable": true,
      "is_summonable": true,
      "is_experimental": false,
      "spawn_egg": {
      "texture": "spawn_egg",
      "texture_index": 0
    }
    },

    "component_groups": {
      "poison_attack": {
        "minecraft:spell_effects": {
          "add_effects": [
            {
              "effect": "poison",
              "duration": 100,
              "amplifier": 0
            }
          ]
        }
      },
      "fire_death": {},
      "normal_death": {}
    },

    "events": {
      "apply_poison": {
        "add": {
          "component_groups": ["poison_attack"]
        }
      },
      "mark_fire_death": {
        "add": {
          "component_groups": ["fire_death"]
        }
      },
      "mark_normal_death": {
        "add": {
          "component_groups": ["normal_death"]
        }
      },
      "on_death": {
        "run_command": {
          "command": [
            "execute if entity @s[has_component=fire_death] run summon item ~ ~ ~ minecraft:baked_potato",
            "execute unless entity @s[has_component=fire_death] run summon item ~ ~ ~ minecraft:poisonous_potato"
          ]
        }
      }
    },

    "components": {
      "minecraft:health": {
        "value": 10,
        "max": 10
      },
      "minecraft:movement": {
        "value": 0.25
      },
      "minecraft:nameable": {
        "always_show": true
      },
      "minecraft:movement.basic": {},
      "minecraft:navigation.walk": {},
      "minecraft:physics": {},
      "minecraft:collision_box": {
        "width": 0.6,
        "height": 0.6
      },
      "minecraft:behavior.random_stroll": {
        "priority": 3
      },
      "minecraft:behavior.look_at_player": {
        "priority": 4,
        "look_distance": 6
      },
      "minecraft:attack": {
        "damage": 3
      },
      "minecraft:behavior.melee_attack": {
        "priority": 1,
        "speed_multiplier": 1.2,
        "track_target": true
      },
      "minecraft:behavior.nearest_attackable_target": {
        "priority": 2,
        "entity_types": [
          {
            "filters": {
              "test": "is_family",
              "subject": "other",
              "value": "player"
            },
            "max_dist": 16
          }
        ]
      },
      "minecraft:damage_sensor": [
        {
          "triggers": {
            "on_damage": {
              "filters": {
                "test": "is_family",
                "subject": "other",
                "value": "player"
              },
              "event": "apply_poison"
            },
            "deals_damage": true
          }
        },
        {
          "triggers": {
            "on_damage": {
              "filters": {
                "test": "has_damage_cause",
                "value": "fire"
              },
              "event": "mark_fire_death"
            }
          }
        },
        {
          "triggers": {
            "on_damage": {
              "event": "mark_normal_death"
            }
          }
        }
      ]
    }
  }
}